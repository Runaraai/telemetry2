# Omniference Configuration
# Copy this file to .env and update the values for your deployment

# ============================================================================
# API Base URL Configuration
# ============================================================================
# Set this to your domain - this is the PRIMARY configuration variable
# Examples:
#   - For omniference.com: https://omniference.com
#   - For voertx.cloud: https://voertx.cloud
#   - For local development: http://localhost:8000
API_BASE_URL=https://omniference.com

# Frontend API URL (used by React frontend)
# If not set, automatically uses API_BASE_URL
# Set to empty string for relative URLs in local development
FRONTEND_API_URL=${API_BASE_URL}

# Telemetry Backend URL (for remote instances to send metrics)
# If not set, automatically uses API_BASE_URL
# Must be publicly accessible
TELEMETRY_BACKEND_URL=${API_BASE_URL}

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed CORS origins
# If not set, defaults include both voertx.cloud and omniference.com
CORS_ORIGINS=https://omniference.com,https://www.omniference.com,http://localhost:3000,http://localhost:5173

# ============================================================================
# Nginx Configuration
# ============================================================================
# Server name(s) for nginx - space-separated for multiple domains
# Examples:
#   - Single: omniference.com
#   - Multiple: omniference.com www.omniference.com
NGINX_SERVER_NAME=omniference.com www.omniference.com

# ============================================================================
# Telemetry Configuration
# ============================================================================
TELEMETRY_AGENT_IMAGE=allyin/telemetry-agent:latest
TELEMETRY_DATABASE_URL=postgresql+asyncpg://postgres:password@timescaledb:5432/omniference
TELEMETRY_REDIS_URL=redis://redis:6379/0
TELEMETRY_CREDENTIAL_SECRET_KEY=change-me-please

# ============================================================================
# API Keys (Optional)
# ============================================================================
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LAMBDA_API_KEY=
GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=
