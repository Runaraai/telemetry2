# Omniference Configuration
# Copy this file to .env and update the values for your deployment

# ============================================================================
# API Base URL Configuration
# ============================================================================
# Set this to your domain - this is the PRIMARY configuration variable
# Examples:
#   - Production: https://your-domain.com
#   - Local development: http://localhost:8000
API_BASE_URL=http://localhost:8000

# Frontend API URL (used by React frontend)
# If not set, automatically uses API_BASE_URL
# Set to empty string for relative URLs in local development
FRONTEND_API_URL=${API_BASE_URL}

# Telemetry Backend URL (for remote instances to send metrics)
# If not set, automatically uses API_BASE_URL
# Must be publicly accessible from GPU instances
TELEMETRY_BACKEND_URL=${API_BASE_URL}

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed CORS origins
# If not set, defaults to localhost only
# For production, set to your domain(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# Nginx Configuration (production only)
# ============================================================================
# Server name(s) for nginx - space-separated for multiple domains
NGINX_SERVER_NAME=localhost

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection string (required)
TELEMETRY_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/omniference

# Redis URL (optional - in-memory broker is used if not set)
# TELEMETRY_REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Security Keys (REQUIRED - generate with: openssl rand -hex 32)
# ============================================================================
JWT_SECRET_KEY=change-me-generate-a-random-string
TELEMETRY_CREDENTIAL_SECRET_KEY=change-me-generate-a-random-string

# ============================================================================
# Demo Account (created on startup if it doesn't exist)
# ============================================================================
DEMO_ACCOUNT_EMAIL=demo@omniference.com
DEMO_ACCOUNT_PASSWORD=demo

# Migration fallback email (used to assign orphaned rows during DB migrations)
MIGRATION_FALLBACK_EMAIL=demo@omniference.com

# ============================================================================
# Telemetry Agent
# ============================================================================
TELEMETRY_AGENT_IMAGE=allyin/telemetry-agent:latest

# ============================================================================
# Cloud Provider API Keys (Optional)
# ============================================================================
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# LAMBDA_API_KEY=

# Scaleway
# SCALEWAY_ACCESS_KEY=
# SCALEWAY_SECRET_KEY=
# SCALEWAY_PROJECT_ID=

# Nebius
# NEBIUS_KEY_ID=
# NEBIUS_SECRET_KEY=
# NEBIUS_SERVICE_ACCOUNT_ID=
# NEBIUS_PROJECT_ID=
# NEBIUS_SUBNET_ID=
# NEBIUS_REGION=eu-north1
# NEBIUS_PRIVATE_KEY=

# GitHub (for provisioning agent releases)
# GITHUB_USERNAME=
# GITHUB_TOKEN=

# HuggingFace
# HF_TOKEN=

# ============================================================================
# EC2 Deployment Server (SSH for deploy scripts)
# ============================================================================
# Used by scripts: deploy-via-git.sh, fix-ssh-and-deploy.sh, deploy-via-aws.sh
EC2_SSH_HOST=3.19.87.64
EC2_SSH_USER=ec2-user
EC2_PEM_FILE=omniference-key.pem
EC2_INSTANCE_ID=i-0d3bb2002c040644e
EC2_REGION=us-east-2
EC2_APP_PATH=/opt/omniference/app
